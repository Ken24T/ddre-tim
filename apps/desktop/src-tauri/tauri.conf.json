{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DDRE TiM Desktop",
  "version": "0.2.0",
  "identifier": "au.com.ddre.tim.desktop",
  "build": {
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DDRE TiM Desktop",
        "width": 1180,
        "height": 860,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}